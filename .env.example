# ============================================================
# Cấu hình biến môi trường cho Smart AI Security Camera System
# Copy file này thành .env và điền các thông tin của bạn
# ============================================================

# --- Google Gemini API (NLG Engine) ---
# Lấy key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# --- Telegram Bot Notification ---
# Bot token từ @BotFather
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE
# Chat ID của người nhận thông báo (lấy từ getUpdates hoặc chat id bot)
TELEGRAM_CHAT_ID=PASTE_YOUR_TELEGRAM_CHAT_ID_HERE

# --- Camera Source Config ---
# Mặc định: 0 (webcam)
# Ví dụ RTSP IP Camera: rtsp://username:password@ip_address:554/Streaming/Channels/101
CAMERA_SOURCE=0
